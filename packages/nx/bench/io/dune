(executable
 (name bench_io)
 (libraries nx nx.io thumper unix))

; Kept out of runtest: filesystem and codec throughput are measured explicitly
; with `dune build @packages/nx/bench/io/bench`.
(rule
 (alias bench)
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_io.exe} -q --ci)
   (diff? nx_io.thumper nx_io.thumper.corrected))))
