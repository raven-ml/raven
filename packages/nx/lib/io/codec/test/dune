(rule
 (target deflate_core_sanitize.exe)
 (deps
  deflate_core_test.c
  ../nx_io_codec.h
  ../nx_io_deflate.c
  ../nx_io_deflate_encode.c)
 (action
  (run
   cc
   -std=c11
   -O1
   -g
   -fno-omit-frame-pointer
   -fsanitize=address,undefined
   -Wall
   -Wextra
   -Wpedantic
   -Werror
   -DNX_IO_CODEC_NO_OCAML
   -I..
   %{dep:deflate_core_test.c}
   %{dep:../nx_io_deflate.c}
   %{dep:../nx_io_deflate_encode.c}
   -o
   %{target})))

(rule
 (alias codec-sanitize)
 (action (run %{dep:deflate_core_sanitize.exe})))

