(executable
 (name bench_kaun)
 (libraries nx rune kaun vega thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/kaun/bench/bench_kaun.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_kaun.exe} -q)
   (diff? kaun.thumper kaun.thumper.corrected))))
