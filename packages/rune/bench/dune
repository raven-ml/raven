(executable
 (name bench_rune)
 (libraries nx rune thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/rune/bench/bench_rune.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_rune.exe} -q)
   (diff? rune.thumper rune.thumper.corrected))))
