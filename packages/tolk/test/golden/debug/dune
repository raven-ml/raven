(executable
 (name generate_actual)
 (libraries tolk tolk.uop unix))

(rule
 (alias runtest)
 (package tolk)
 (deps
  (:generator generate_actual.exe)
  elementwise_add.expected
  elementwise_add_opt.expected)
 (action
  (no-infer
   (progn
    (setenv
     DEBUG
     6
     (run %{generator} .))
    (diff elementwise_add.expected elementwise_add.actual)
    (diff elementwise_add_opt.expected elementwise_add_opt.actual)))))
