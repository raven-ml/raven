#include <metal_stdlib>
using namespace metal;
kernel void elementwise_add(device float* data0, device float* data1, device float* data2, uint3 gid [[threadgroup_position_in_grid]], uint3 lid [[thread_position_in_threadgroup]]) {
  int gidx0 = gid.x; /* 256 */
  float val0 = (*(data0+gidx0));
  float val1 = (*(data1+gidx0));
  *(data2+gidx0) = (val0+val1);
}
