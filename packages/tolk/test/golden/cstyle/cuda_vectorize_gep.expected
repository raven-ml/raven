#define INFINITY (__int_as_float(0x7f800000))
#define NAN (__int_as_float(0x7fffffff))
template <class T, class F> __device__ __forceinline__ T tg_bitcast(F v) { union U { F f; T t; }; U u; u.f = v; return u.t; }
extern "C" __global__ void __launch_bounds__(1) test(float* data0, float* data1) {
  float val0 = (*(data0+0));
  float val1 = (*(data0+1));
  float val2 = (*(data0+2));
  float val3 = (*(data0+3));
  *(data1+0) = make_float4(val0,val1,val2,val3).z;
}
