(executable
 (name main)
 (libraries tolk tolk.uop tolk_parity_helpers))

(rule
 (package tolk)
 (targets
  stage5_cpu.actual
  stage5_cuda.actual
  stage5_metal.actual
  stage5_opencl.actual
  stage7_cpu.actual
  stage7_cuda.actual
  stage7_metal.actual
  stage7_opencl.actual)
 (action
  (run ./main.exe .)))

(rule
 (alias runtest)
 (package tolk)
 (action
  (progn
   (diff stage5_cpu.expected stage5_cpu.actual)
   (diff stage5_cuda.expected stage5_cuda.actual)
   (diff stage5_metal.expected stage5_metal.actual)
   (diff stage5_opencl.expected stage5_opencl.actual)
   (diff stage7_cpu.expected stage7_cpu.actual)
   (diff stage7_cuda.expected stage7_cuda.actual)
   (diff stage7_metal.expected stage7_metal.actual)
   (diff stage7_opencl.expected stage7_opencl.actual))))
