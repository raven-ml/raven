#define INFINITY (__int_as_float(0x7f800000))
#define NAN (__int_as_float(0x7fffffff))
template <class T, class F> __device__ __forceinline__ T tg_bitcast(F v) { union U { F f; T t; }; U u; u.f = v; return u.t; }
extern "C" __global__ void __launch_bounds__(1) matmul_small(float* data0_-1, float* data1_-1, float* data2_-1) {
  float buf0[1];
  int gidx0 = blockIdx.x; /* 4 */
  int gidx1 = blockIdx.y; /* 4 */
  int alu0 = (gidx1<<2);
  *(buf0+0) = 0.0f;
  for (int Ridx2 = 0; Ridx2 < 4; Ridx2++) {
    float val0 = (*(data0_-1+(alu0+Ridx2)));
    float val1 = (*(data1_-1+(gidx0+(Ridx2<<2))));
    *(buf0+0) = ((*(buf0+0))+(val0*val1));
  }
  *(data2_-1+(gidx0+alu0)) = (*(buf0+0));
}
