#include <metal_stdlib>
using namespace metal;
kernel void sum_reduce(device float* data0_-1, device float* data1_-1, uint3 gid [[threadgroup_position_in_grid]], uint3 lid [[thread_position_in_threadgroup]]) {
  float buf0[1];
  *(buf0+0) = 0.0f;
  for (int Ridx0 = 0; Ridx0 < 256; Ridx0++) {
    float val0 = (*(data0_-1+Ridx0));
    *(buf0+0) = ((*(buf0+0))+val0);
  }
  *(data1_-1+0) = (*(buf0+0));
}
