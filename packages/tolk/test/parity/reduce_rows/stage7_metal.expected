#include <metal_stdlib>
using namespace metal;
kernel void reduce_rows(device float* data0_-1, device float* data1_-1, uint3 gid [[threadgroup_position_in_grid]], uint3 lid [[thread_position_in_threadgroup]]) {
  float buf0[1];
  int gidx0 = gid.x; /* 8 */
  *(buf0+0) = 0.0f;
  for (int Ridx1 = 0; Ridx1 < 32; Ridx1++) {
    float val0 = (*(data0_-1+((gidx0<<5)+Ridx1)));
    *(buf0+0) = ((*(buf0+0))+val0);
  }
  *(data1_-1+gidx0) = (*(buf0+0));
}
