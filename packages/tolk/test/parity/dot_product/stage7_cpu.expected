void dot_product(float* restrict data0_-1, float* restrict data1_-1, float* restrict data2_-1) {
  float buf0[1];
  *(buf0+0) = 0.0f;
  for (int Ridx0 = 0; Ridx0 < 128; Ridx0++) {
    float val0 = (*(data0_-1+Ridx0));
    float val1 = (*(data1_-1+Ridx0));
    *(buf0+0) = ((*(buf0+0))+(val0*val1));
  }
  *(data2_-1+0) = (*(buf0+0));
}
