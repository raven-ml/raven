#include <metal_stdlib>
using namespace metal;
kernel void multi_output(device float* data0_-1, device float* data1_-1, device float* data2_-1, uint3 gid [[threadgroup_position_in_grid]], uint3 lid [[thread_position_in_threadgroup]]) {
  int gidx0 = gid.x; /* 256 */
  float val0 = (*(data0_-1+gidx0));
  *(data1_-1+gidx0) = (val0+1.0f);
  *(data2_-1+gidx0) = (val0*2.0f);
}
