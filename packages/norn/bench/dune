(executable
 (name bench_norn)
 (libraries nx rune norn thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/norn/bench/bench_norn.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_norn.exe} -q)
   (diff? norn.thumper norn.thumper.corrected))))
