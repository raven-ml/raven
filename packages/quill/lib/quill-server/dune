(library
 (name quill_server)
 (public_name quill.server)
 (modules quill_server httpd protocol assets)
 (private_modules httpd protocol assets)
 (libraries
  quill
  quill.project
  quill.markdown
  jsont
  jsont.bytesrw
  unix
  threads.posix))

; Generate assets.ml from committed frontend/dist

(rule
 (targets assets.ml)
 (deps
  (glob_files frontend/dist/*.js)
  (glob_files frontend/dist/*.css)
  (glob_files frontend/fonts/*.woff2)
  frontend/index.html
  support/gen_assets.ml)
 (action
  (run ocaml support/gen_assets.ml frontend assets.ml)))
