(data_only_dirs data)

(executable
 (name bench_brot)
 (libraries brot thumper unix))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/brot/bench/bench_brot.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_brot.exe} -q)
   (diff? brot.thumper brot.thumper.corrected))))
