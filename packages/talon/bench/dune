(executable
 (name bench_talon)
 (libraries talon talon.csv thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/talon/bench/bench_talon.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_talon.exe} -q)
   (diff? talon.thumper talon.thumper.corrected))))
