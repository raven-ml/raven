(executable
 (name bench_sowilo)
 (libraries sowilo nx.io nx thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/sowilo/bench/bench_sowilo.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_sowilo.exe} -q)
   (diff? sowilo.thumper sowilo.thumper.corrected))))
