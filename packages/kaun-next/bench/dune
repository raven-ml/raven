(executable
 (name bench_kaun_next)
 (libraries nx rune-next kaun kaun-next vega thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/kaun-next/bench/bench_kaun_next.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_kaun_next.exe} -q)
   (diff? kaun_next.thumper kaun_next.thumper.corrected))))
