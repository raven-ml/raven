(executable
 (name bench_vega)
 (libraries nx vega thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/vega/bench/bench_vega.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_vega.exe} -q)
   (diff? vega.thumper vega.thumper.corrected))))
