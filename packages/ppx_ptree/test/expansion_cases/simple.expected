      let ptree_label__009_ = x.label in
      {
        weight = ptree_weight__005_;
        optional = ptree_optional__006_;
        label = ptree_label__009_
      }
    let _ = map2
    let iter (f : 'ptree_a 'ptree_b . ('ptree_a, 'ptree_b) Nx.t -> unit)
      (x : t) =
      f x.weight;
      (match x.optional with
       | None -> ()
       | Some ptree_value__010_ -> f ptree_value__010_);
      ()
    let _ = iter
  end[@@ocaml.doc "@inline"][@@merlin.hide ]
