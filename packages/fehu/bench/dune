(executable
 (name bench_fehu)
 (libraries nx fehu thumper))

; Not attached to runtest on purpose: run with `dune build @bench`
; (or `dune exec packages/fehu/bench/bench_fehu.exe -- --explore`).

(rule
 (alias bench)
 ; Serialize bench rules across the workspace: concurrent suites contend
 ; for cores and distort measurements.
 (locks %{project_root}/bench)
 (action
  (progn
   (run %{exe:bench_fehu.exe} -q)
   (diff? fehu.thumper fehu.thumper.corrected))))
