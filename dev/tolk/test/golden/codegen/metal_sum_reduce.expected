#include <metal_stdlib>
using namespace metal;
kernel void sum_reduce(device float* data0, device float* data1, uint3 gid [[threadgroup_position_in_grid]], uint3 lid [[thread_position_in_threadgroup]]) {
  float acc0[1];
  *(acc0+0) = 0.0f;
  for (int Ridx0 = 0; Ridx0 < 256; Ridx0++) {
    float val0 = (*(data0+Ridx0));
    *(acc0+0) = ((*(acc0+0))+val0);
  }
  *(data1+0) = (*(acc0+0));
}
