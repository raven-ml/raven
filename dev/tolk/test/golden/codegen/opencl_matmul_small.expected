__kernel void matmul_small(__global float* data0, __global float* data1, __global float* data2) {
  float acc0[1];
  int gidx0 = get_group_id(0); /* 4 */
  int gidx1 = get_group_id(1); /* 4 */
  int alu0 = (gidx1<<2);
  *(acc0+0) = 0.0f;
  for (int Ridx2 = 0; Ridx2 < 4; Ridx2++) {
    float val0 = (*(data0+(alu0+Ridx2)));
    float val1 = (*(data1+(gidx0+(Ridx2<<2))));
    *(acc0+0) = ((*(acc0+0))+(val0*val1));
  }
  *(data2+(gidx0+alu0)) = (*(acc0+0));
}
