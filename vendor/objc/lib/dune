(rule
 (targets
  ccopts.txt
  ccopts.sexp
  cclibs.sexp
  platform.ml
  platform.mli
  ccomp.ml
  ccomp.mli
  arch.ml
  arch.mli)
 (deps
  (:discover ../config/discover.exe))
 (action
  (run %{discover})))

(rule
 (target objc_impl.o)
 (deps objc_impl.m objc_impl.h ccopts.txt)
 (action
  (run %{cc} %{read-lines:ccopts.txt} -c %{dep:objc_impl.m} -o %{target})))

(rule
 (targets libobjc_impl_archive.a)
 (deps objc_impl.o)
 (action
  (run ar rcs %{targets} %{deps})))

(library
 (name objc)
 (foreign_archives objc_impl_archive)
 (foreign_stubs
  (language c)
  (names objc_stubs))
 (c_library_flags
  :standard
  (:include cclibs.sexp))
 (libraries))
